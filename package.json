	"license": "0-BSD",
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/node": "^20.14.0",
		"esbuild": "^0.25.5",
		"eslint": "^10.0.1",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.7.0",
		"tslib": "^2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.62.1"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
