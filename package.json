{
	"name": "open-anything",
	"version": "1.1.2",
	"description": "Launch any terminal command, application, or website from Obsidian, with per-launcher hotkeys.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node scripts/esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node scripts/esbuild.config.mjs production",
